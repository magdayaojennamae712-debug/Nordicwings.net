# ============================================================
# SkyBook — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real API keys.
# NEVER commit your .env file to GitHub!
# ============================================================

# ── RapidAPI / Sky Scrapper (flight data) ────────────────────
# Get your key at: https://rapidapi.com → your profile → Security
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Stripe (payments) ─────────────────────────────────────────
# Get these at: https://dashboard.stripe.com/apikeys
# Use TEST keys during development (start with sk_test_ / pk_test_)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
# NOTE: Also update STRIPE_PUBLISHABLE_KEY in public/script.js

# ── Server ────────────────────────────────────────────────────
PORT=3000
