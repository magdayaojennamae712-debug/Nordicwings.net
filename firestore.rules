// ============================================================
// SkyBook — Firestore Security Rules
// These rules ensure:
// - Users can only read/write their OWN bookings
// - Nobody can read other users' data
// - Nobody can write fake data
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // BOOKINGS collection
    match /bookings/{bookingId} {

      // ✅ Users can READ their own bookings only
      allow read: if request.auth != null
                  && request.auth.uid == resource.data.userId;

      // ✅ Users can CREATE a booking for themselves only
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.userId is string
                    && request.resource.data.bookingRef is string
                    && request.resource.data.totalPrice is string;

      // ✅ Users can UPDATE only the status field of their OWN booking
      // (for cancellations)
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status'])
                    && request.resource.data.status in ['confirmed', 'cancelled'];

      // ❌ Nobody can delete bookings
      allow delete: if false;
    }

    // Block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
